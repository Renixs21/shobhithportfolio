# ===== CONTACT EMAIL DELIVERY =====
# The inbox that receives messages from your portfolio (you).
OWNER_EMAIL=shobhithbj@gmail.com

# --- Option A: Resend (recommended, 3,000 emails/month free) -------
# 1. Sign up at https://resend.com
# 2. Grab your API key from the dashboard
# 3. Paste it below (and optionally verify a domain for the from address)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM=Portfolio <onboarding@resend.dev>

# --- Option B: Web3Forms (free, fastest to set up) -----------------
# 1. Go to https://web3forms.com and enter your email
# 2. They instantly email you an access key — paste it below
# WEB3FORMS_ACCESS_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# If NEITHER key is set, messages are logged to the server console
# (dev fallback) so the form never crashes.
